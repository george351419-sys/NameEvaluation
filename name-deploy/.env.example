# =============================================
# 名字评测网站 - 环境变量配置
# 使用方法：cp .env.example app/.env 然后填入真实值
# =============================================

# MySQL 数据库连接（本机安装）
# 格式：mysql://用户名:密码@主机:端口/数据库名
DATABASE_URL="mysql://root:你的MySQL密码@localhost:3306/name_db"

# AI 接口 Key（选填其一或两个都填）
DEEPSEEK_API_KEY="sk-xxx"
MINIMAX_API_KEY="sk-xxx"

# 切换 AI 模型：deepseek 或 minimax
LLM_PROVIDER="deepseek"
